APP_NAME="Picia Bakery"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://ftwodev.id/mart
APP_FRONTEND_URL=https://ftwodev.id/mart

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ftwo_mart
DB_USERNAME=ftwo_mart_user
DB_PASSWORD=your_secure_database_password

# Midtrans Configuration (Production)
MIDTRANS_SERVER_KEY=your_production_server_key
MIDTRANS_CLIENT_KEY=your_production_client_key
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_MERCHANT_ID=your_merchant_id

# RajaOngkir Configuration
RAJAONGKIR_API_KEY=your_rajaongkir_api_key
RAJAONGKIR_ACCOUNT_TYPE=starter

# Security
# Generate this with: php artisan key:generate
APP_KEY=
